## kamailio version latest stable to use
KAMAILIO_VERSION=61

## USER and Group to RUN kamailio
STARTER_KAM_USER=kamailio
STARTER_KAM_GROUP=kamailio

## Kamailio Root folder and Main File
CONFIGS_FOLDER=/etc/kamailio
CFGFILE=router.cfg

RUNDIR=/var/run/kamailio

## SHM and PKG Memory values
SHM_MEMORY=1024
PKG_MEMORY=128

## MACROS setup
#WITH_SIPTRACE=true
WITH_PROM_STATS=true
#WITH_DMQUEUE=true
#WITH_TLS=true
WITH_PROM_STATS=true
WITH_ASYNC_INSERT=true
WITH_LOG_STDERR=true
WITH_MID_REGISTRAR_SUPPORT=true
##WITH_RTPENGINE=true

## SOCKETS INFO
PROM_STATS_LISTEN=tcp:127.0.0.1:8123
##LISTEN_IP_ADDRESS_DISPATCHER=udp:127.0.0.1:5060
DISPATCHER_DEFAULT_SOCKNAME=lan-internal

## DB information
DB_CONNECTION=postgres:postgres@127.0.0.1:5432/kamailio
